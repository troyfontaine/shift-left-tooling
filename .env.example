# Environment variable template
# Copy this file to .env and fill in your credentials
# Note: .env should NOT be committed to version control

# GitHub API Authentication
# Generate token at https://github.com/settings/tokens
# Requires permissions: 'repo' (all), 'read:org' (if checking org repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Jira API Configuration
# JIRA_URL: Your Jira instance URL (e.g., https://your-company.atlassian.net)
# JIRA_TOKEN: Your Jira API token or password
#   Generate token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-company.atlassian.net
JIRA_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Jira username (optional, defaults to 'automation')
# JIRA_USERNAME=your-username

# Branch naming pattern configuration
# Regex pattern for validating branch names. This pattern is used by validate_branch_naming.py
# to ensure branch names follow your conventions.
#
# The validation also supports:
#   - Jira tickets: Extracted with pattern [A-Z][A-Z0-9]*-\d+ (e.g., PROJ-123, ABC123-456)
#   - GitHub issues: Patterns like gh123, GH456, gh-789, GH-123
#
# Default pattern: ^[A-Z]+-\d+ (Jira style: PROJ-123)
# Other examples:
#   ^[A-Z]+-\d+              - Jira style: PROJ-123
#   ^(feature|bugfix)/.*     - Type-based: feature/my-feature or bugfix/my-fix
#   ^[a-z0-9]+-[a-z0-9-]+$   - Kebab-case: my-feature-name
#   ^(main|develop|release/.*)$ - Branch protection patterns
BRANCH_NAMING_PATTERN=^[A-Z]+-\d+

# Logging level
# Options: debug, info, warning, error
LOG_LEVEL=info

# Optional: Docker Hub credentials for publishing images
# DOCKERHUB_USERNAME=your-username
# DOCKERHUB_TOKEN=your-dockerhub-token
